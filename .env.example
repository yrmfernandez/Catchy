# =============================================================
# Catchy — environment template
# Copy to `.env` and fill in. NEVER commit the real .env.
# =============================================================

# ---- Core ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Database (PostgreSQL) ----
POSTGRES_USER=catchy
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=catchy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis (cache + Celery broker) ----
REDIS_URL=redis://redis:6379/0

# ---- Auth (set a long random value in prod) ----
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# ---- LLM analyst (Gemini first; provider-swappable) ----
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-flash

# ---- Threat intelligence (added at M5; optional until then) ----
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
HIBP_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
